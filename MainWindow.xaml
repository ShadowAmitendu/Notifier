<Window
    x:Class="Notifier.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Notifier"
    xmlns:models="using:Notifier.Models"
    Title="Site Monitor Dashboard">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             Custom Title Bar — Grid registered via SetTitleBar().
             The WinUI TitleBar control crashes unpackaged (0xC000027B).
             ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left side app identity -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="4,0,0,0" Spacing="6">
                <!-- Hamburger — toggles NavView pane open/closed -->
                <Button x:Name="HamburgerButton"
                        Click="HamburgerButton_Click"
                        ToolTipService.ToolTip="Toggle navigation pane"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="40" Height="40"
                        Padding="0"
                        CornerRadius="4">
                    <FontIcon Glyph="&#xE700;" FontSize="16"/>
                </Button>

                <!-- Back button — navigates to the previous page -->
                <Button x:Name="BackButton"
                        Click="BackButton_Click"
                        ToolTipService.ToolTip="Go back"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="40" Height="40"
                        Padding="0"
                        CornerRadius="4"
                        IsEnabled="False">
                    <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                </Button>

                <!-- App icon -->
                <FontIcon Glyph="&#xE774;" FontSize="15"
                          Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                          VerticalAlignment="Center"/>

                <!-- App name — normal body weight/size, not bold -->
                <TextBlock Text="Notifier"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Normal"/>

                <!-- Subtitle — muted, smaller -->
                <TextBlock x:Name="TitlebarStatusText"
                           Text="Active"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
            </StackPanel>

            <!-- Right side: Check Now button (placed before system caption buttons) -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="0,0,148,0" Spacing="8">
                <Button x:Name="TitleCheckNowButton"
                        Style="{ThemeResource DefaultButtonStyle}"
                        Click="OnCheckNowClick"
                        ToolTipService.ToolTip="Run update check now"
                        Height="32" Padding="12,0,12,0" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                        <TextBlock Text="Check Now" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             NavigationView — left pane, hamburger owned by TitleBar.
             IsSettingsVisible="False" — we add our own footer item.
             ══════════════════════════════════════════════════════════ -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsSettingsVisible="False"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsTitleBarAutoPaddingEnabled="False"
            CompactModeThresholdWidth="0"
            ExpandedModeThresholdWidth="720"
            OpenPaneLength="220"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavDashboard" Tag="Dashboard" Content="Dashboard">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="ViewAll"/></NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="NavAddSite" Tag="AddSite" Content="Add Site">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Add"/></NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="NavLogs" Tag="Logs" Content="History Logs">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="AllApps"/></NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="NavHelp" Tag="Help" Content="Help &amp; Docs">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Help"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <!-- Single Settings item — IsSettingsVisible=False hides the built-in one -->
                <NavigationViewItem x:Name="NavSettings" Tag="Settings" Content="Settings">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Setting"/></NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="NavAbout" Tag="About" Content="About">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE946;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- ══════════════════════════════════════════════════════
                 Content pages — EntranceThemeTransition gives each
                 page a smooth slide-in when it becomes visible.
                 ══════════════════════════════════════════════════════ -->
            <NavigationView.Content>
                <Grid>

                    <!-- ─────────────────── Dashboard ─────────────────── -->
                    <Grid x:Name="DashboardPage" Padding="24,16,24,16" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Dashboard"
                                       Style="{ThemeResource TitleTextBlockStyle}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Click="OnAddSiteNavClick"
                                    Style="{ThemeResource DefaultButtonStyle}"
                                    VerticalAlignment="Center"
                                    Height="32" Padding="12,0,12,0" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                    <TextBlock Text="Add Site" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Search, Filter, & Sort Panel -->
                        <Grid Grid.Row="1" Margin="0,0,0,16" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SearchBox"
                                     Grid.Column="0"
                                     PlaceholderText="Search sites by name or URL..."
                                     TextChanged="OnSearchBoxTextChanged"
                                     VerticalAlignment="Center"
                                     Height="36"
                                     CornerRadius="4"/>

                            <ComboBox x:Name="FilterComboBox"
                                      Grid.Column="1"
                                      SelectedIndex="0"
                                      Width="160"
                                      Height="36"
                                      VerticalAlignment="Center"
                                      CornerRadius="4"
                                      SelectionChanged="OnFilterSelectionChanged">
                                <ComboBoxItem Content="All Statuses"/>
                                <ComboBoxItem Content="Changed"/>
                                <ComboBoxItem Content="Success"/>
                                <ComboBoxItem Content="Error"/>
                                <ComboBoxItem Content="Pending"/>
                            </ComboBox>

                            <ComboBox x:Name="SortComboBox"
                                      Grid.Column="2"
                                      SelectedIndex="0"
                                      Width="160"
                                      Height="36"
                                      VerticalAlignment="Center"
                                      CornerRadius="4"
                                      SelectionChanged="OnSortSelectionChanged">
                                <ComboBoxItem Content="Sort: Name (A-Z)"/>
                                <ComboBoxItem Content="Sort: Name (Z-A)"/>
                                <ComboBoxItem Content="Sort: Last Checked"/>
                                <ComboBoxItem Content="Sort: Next Check"/>
                            </ComboBox>
                        </Grid>

                        <!-- Empty state -->
                        <TextBlock x:Name="EmptyTextBlock"
                                   Grid.Row="2"
                                   Text="No sites are currently monitored.&#10;Use 'Add Site' in the navigation to configure one."
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                   Visibility="Collapsed" TextAlignment="Center"/>

                        <!-- Sites list — staggered entrance + reposition on item change -->
                        <ListView x:Name="SitesListView"
                                  Grid.Row="2"
                                  SelectionMode="None"
                                  Margin="0,0,0,8"
                                  IsItemClickEnabled="False">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition IsStaggeringEnabled="True"/>
                                    <RepositionThemeTransition IsStaggeringEnabled="False"/>
                                    <AddDeleteThemeTransition/>
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:SiteEntry">
                                    <Border BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="14,10" Margin="0,4,0,6"
                                            Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="3">
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <FontIcon Glyph="{x:Bind StatusGlyph}" 
                                                              Foreground="{x:Bind StatusColor}" 
                                                              FontSize="14" 
                                                              VerticalAlignment="Center"/>
                                                    <TextBlock Text="{x:Bind Name}"
                                                               Style="{ThemeResource SubtitleTextBlockStyle}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Url}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{x:Bind DisplayLastChecked}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                    <TextBlock Text="•"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                    <TextBlock Text="{x:Bind DisplayMode}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                    <TextBlock Text="•"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                    <TextBlock Text="{x:Bind DisplayInterval}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind LastStatusMessage}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Foreground="{x:Bind StatusColor}"
                                                           Visibility="{x:Bind StatusMessageVisibility}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <Button Click="OnViewDiffClick"
                                                        Tag="{x:Bind}"
                                                        Visibility="{x:Bind ViewDiffButtonVisibility}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon Glyph="&#xE7B3;" FontSize="13"/>
                                                        <TextBlock Text="View Diff" FontSize="12" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Click="OnEditSiteClick"
                                                        Tag="{x:Bind}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon Glyph="&#xE70F;" FontSize="13"/>
                                                        <TextBlock Text="Edit" FontSize="12" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Click="OnRemoveSiteClick"
                                                        Tag="{x:Bind}"
                                                        Style="{ThemeResource AccentButtonStyle}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="13"/>
                                                        <TextBlock Text="Remove" FontSize="12" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <!-- ─────────────────── Logs Page ─────────────────── -->
                    <Grid x:Name="LogsPage" Padding="24,16,24,16" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="History Logs"
                                       Style="{ThemeResource TitleTextBlockStyle}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Click="OnClearLogsClick"
                                    Style="{ThemeResource DefaultButtonStyle}"
                                    VerticalAlignment="Center"
                                    Height="32" Padding="12,0,12,0" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                    <TextBlock Text="Clear Logs" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Empty logs state -->
                        <TextBlock x:Name="EmptyLogsTextBlock"
                                   Grid.Row="1"
                                   Text="No checks have run yet."
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                   Visibility="Collapsed" TextAlignment="Center"/>

                        <!-- Logs list -->
                        <ListView x:Name="LogsListView"
                                  Grid.Row="1"
                                  SelectionMode="None"
                                  Margin="0,0,0,8"
                                  IsItemClickEnabled="False">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition IsStaggeringEnabled="True"/>
                                    <RepositionThemeTransition IsStaggeringEnabled="False"/>
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:CheckLogEntry">
                                    <Border BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                            BorderThickness="1" CornerRadius="6"
                                            Padding="12,8" Margin="0,2,0,4"
                                            Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Status Icon -->
                                            <FontIcon Grid.Column="0" 
                                                      Glyph="{x:Bind StatusGlyph}" 
                                                      Foreground="{x:Bind StatusColor}" 
                                                      FontSize="16" 
                                                      VerticalAlignment="Center" 
                                                      Margin="0,0,12,0"/>
                                            
                                            <!-- Info -->
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{x:Bind SiteName}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"/>
                                                    <TextBlock Text="•"
                                                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                                               FontSize="13"/>
                                                    <TextBlock Text="{x:Bind Status}"
                                                               Foreground="{x:Bind StatusColor}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"/>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Details}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            
                                            <!-- Timestamp -->
                                            <TextBlock Grid.Column="2" 
                                                       Text="{x:Bind DisplayTime}" 
                                                       FontSize="11" 
                                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <!-- ─────────────── Add Site (inline form) ─────────────── -->
                    <Grid x:Name="AddSitePage" Padding="24,16,24,16" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="AddSiteTitleText"
                                   Grid.Row="0"
                                   Text="Add New Site"
                                   Style="{ThemeResource TitleTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="14" MaxWidth="600" HorizontalAlignment="Left">

                                <TextBox x:Name="AddNameTextBox"
                                         Header="Site Name"
                                         PlaceholderText="e.g. My Blog"
                                         Width="560" HorizontalAlignment="Left"/>

                                <TextBox x:Name="AddUrlTextBox"
                                         Header="Site URL (HTTP / HTTPS)"
                                         PlaceholderText="https://example.com"
                                         Width="560" HorizontalAlignment="Left"/>

                                <ComboBox x:Name="AddModeComboBox"
                                          Header="Monitoring Mode"
                                          SelectedIndex="0"
                                          Width="560" HorizontalAlignment="Left"
                                          SelectionChanged="OnAddModeSelectionChanged">
                                    <ComboBoxItem Content="Text Content (Detects visible content changes)"/>
                                    <ComboBoxItem Content="DOM / HTML Structure (Detects code, tags, and links changes)"/>
                                    <ComboBoxItem Content="Both (Detects both visible text and HTML changes)"/>
                                    <ComboBoxItem Content="CSS Selector / XPath (Monitor a specific webpage element)"/>
                                </ComboBox>

                                <TextBox x:Name="AddSelectorTextBox"
                                         Header="CSS Selector or XPath"
                                         PlaceholderText="e.g. #content, .article-body, or //div[@id='main']"
                                         Width="560" HorizontalAlignment="Left"
                                         Visibility="Collapsed"/>

                                <!-- Custom Interval Settings -->
                                <CheckBox x:Name="AddCustomIntervalCheck"
                                          Content="Use custom check interval for this site"
                                          Margin="0,4,0,0"
                                          Checked="OnAddCustomIntervalCheckChanged"
                                          Unchecked="OnAddCustomIntervalCheckChanged"/>

                                <StackPanel x:Name="AddCustomIntervalPanel" Spacing="6" Visibility="Collapsed" Margin="12,0,0,0">
                                    <TextBlock Text="Custom Check Interval"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               FontWeight="SemiBold"/>
                                    <Grid ColumnSpacing="10" Width="548" HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <NumberBox x:Name="AddIntervalBox"
                                                   Grid.Column="0"
                                                   Value="60" Minimum="1" Maximum="1440"
                                                   SpinButtonPlacementMode="Compact"
                                                   HorizontalAlignment="Stretch"/>
                                        <ComboBox x:Name="AddIntervalUnit"
                                                  Grid.Column="1"
                                                  SelectedIndex="0"
                                                  HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="Minutes"/>
                                            <ComboBoxItem Content="Hours"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>

                                <!-- Advanced Request Options Expander -->
                                <Expander Header="Advanced Request Options"
                                          HorizontalAlignment="Left"
                                          Width="560"
                                          Margin="0,8,0,0">
                                    <StackPanel Spacing="12" Padding="16">
                                        <ComboBox x:Name="AddMethodComboBox"
                                                  Header="HTTP Request Method"
                                                  SelectedIndex="0"
                                                  Width="500"
                                                  SelectionChanged="OnAddMethodChanged">
                                            <ComboBoxItem Content="GET"/>
                                            <ComboBoxItem Content="POST"/>
                                        </ComboBox>

                                        <TextBox x:Name="AddHeadersTextBox"
                                                 Header="Custom Request Headers (one per line, e.g. User-Agent: CustomBot)"
                                                 PlaceholderText="HeaderName: HeaderValue"
                                                 AcceptsReturn="True"
                                                 Height="80"
                                                 Width="500"/>

                                        <TextBox x:Name="AddCookiesTextBox"
                                                 Header="Custom Cookies (Cookie Header String)"
                                                 PlaceholderText="sessionid=12345abc; key=value"
                                                 Width="500"/>

                                        <TextBox x:Name="AddBodyTextBox"
                                                 Header="Request Body Content (POST only)"
                                                 AcceptsReturn="True"
                                                 Height="80"
                                                 Width="500"
                                                 Visibility="Collapsed"/>
                                    </StackPanel>
                                </Expander>

                                <TextBlock x:Name="AddValidationText"
                                           Foreground="#DC2626"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                    HorizontalAlignment="Left" Spacing="10" Margin="0,16,0,0">
                            <Button x:Name="AddSiteSaveButton"
                                    Content="Add Site"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    Click="OnAddSiteSaveClick"/>
                            <Button x:Name="AddSiteCancelButton"
                                    Content="Clear"
                                    Click="OnAddSiteClearClick"/>
                        </StackPanel>
                    </Grid>

                    <!-- ─────────────── Settings (inline form) ─────────────── -->
                    <Grid x:Name="SettingsPage" Padding="24,16,24,16" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Settings"
                                   Style="{ThemeResource TitleTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">

                                <!-- Enable/Disable Periodic Monitoring -->
                                <StackPanel Spacing="8" Width="560" HorizontalAlignment="Left">
                                    <TextBlock Text="Automatic Background Checking"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               FontWeight="SemiBold"/>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="SettingsEnableButton"
                                                Grid.Column="0"
                                                Click="OnSettingsEnableClick"
                                                HorizontalAlignment="Stretch"
                                                Height="36" CornerRadius="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE73E;" FontSize="14"/>
                                                <TextBlock Text="Enable Checking"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="SettingsDisableButton"
                                                Grid.Column="1"
                                                Click="OnSettingsDisableClick"
                                                HorizontalAlignment="Stretch"
                                                Height="36" CornerRadius="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE711;" FontSize="14"/>
                                                <TextBlock Text="Disable Checking"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <!-- Check interval -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Check Interval"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               FontWeight="SemiBold"/>
                                    <Grid ColumnSpacing="10" Width="560" HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <NumberBox x:Name="SettingsIntervalBox"
                                                   Grid.Column="0"
                                                   Value="60" Minimum="1" Maximum="1440"
                                                   SpinButtonPlacementMode="Compact"
                                                   HorizontalAlignment="Stretch"
                                                   ValueChanged="OnSettingsIntervalBoxChanged"/>
                                        <ComboBox x:Name="SettingsIntervalUnit"
                                                  Grid.Column="1"
                                                  HorizontalAlignment="Stretch"
                                                  SelectionChanged="OnSettingsIntervalUnitChanged">
                                            <ComboBoxItem Content="Minutes"/>
                                            <ComboBoxItem Content="Hours"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>

                                <!-- Startup -->
                                <CheckBox x:Name="SettingsStartupCheck"
                                          Content="Run at Windows startup"
                                          Margin="0,6,0,0"
                                          Checked="OnSettingsStartupCheckChanged"
                                          Unchecked="OnSettingsStartupCheckChanged"/>

                                <!-- Theme Toggle -->
                                <ComboBox x:Name="SettingsThemeComboBox"
                                          Header="App Color Theme"
                                          SelectedIndex="0"
                                          Width="560" HorizontalAlignment="Left"
                                          Margin="0,6,0,0"
                                          SelectionChanged="OnSettingsThemeChanged">
                                    <ComboBoxItem Content="Use System Setting"/>
                                    <ComboBoxItem Content="Light Theme"/>
                                    <ComboBoxItem Content="Dark Theme"/>
                                </ComboBox>

                                <!-- Jitter -->
                                <NumberBox x:Name="SettingsJitterBox"
                                           Header="Max Random Delay Jitter (seconds)"
                                           Value="30" Minimum="0" Maximum="300"
                                           SpinButtonPlacementMode="Compact"
                                           Width="560" HorizontalAlignment="Left"
                                           ValueChanged="OnSettingsJitterBoxChanged"/>

                                 <!-- Sound Alerts -->
                                 <StackPanel Spacing="6" Width="560" HorizontalAlignment="Left" Margin="0,6,0,0">
                                     <TextBlock Text="Sound Notifications"
                                                Style="{ThemeResource BodyTextBlockStyle}"
                                                FontWeight="SemiBold"/>
                                     <CheckBox x:Name="SettingsPlaySoundCheck"
                                               Content="Play sound on update detection"
                                               Checked="OnSettingsPlaySoundCheckChanged"
                                               Unchecked="OnSettingsPlaySoundCheckChanged"/>
                                     <Grid ColumnSpacing="10" Margin="0,4,0,0">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*"/>
                                             <ColumnDefinition Width="Auto"/>
                                             <ColumnDefinition Width="Auto"/>
                                         </Grid.ColumnDefinitions>
                                         <TextBox x:Name="SettingsSoundPathTextBox"
                                                  Grid.Column="0"
                                                  PlaceholderText="Path to .mp3 or .wav file..."
                                                  IsReadOnly="True"
                                                  Height="36" CornerRadius="4"/>
                                         <Button x:Name="SettingsBrowseSoundButton"
                                                 Grid.Column="1"
                                                 Click="OnBrowseSoundClick"
                                                 Height="36" Width="90" CornerRadius="4"
                                                 Content="Browse..."/>
                                         <Button x:Name="SettingsTestSoundButton"
                                                 Grid.Column="2"
                                                 Click="OnTestSoundClick"
                                                 Height="36" Width="70" CornerRadius="4"
                                                 Content="Test"/>
                                     </Grid>
                                 </StackPanel>

                                 <!-- Log Management -->
                                 <StackPanel Spacing="6" Width="560" HorizontalAlignment="Left" Margin="0,12,0,0">
                                     <TextBlock Text="History Log Management"
                                                Style="{ThemeResource BodyTextBlockStyle}"
                                                FontWeight="SemiBold"/>
                                     <CheckBox x:Name="SettingsAutoPruneCheck"
                                               Content="Automatically prune history logs"
                                               Checked="OnSettingsAutoPruneCheckChanged"
                                               Unchecked="OnSettingsAutoPruneCheckChanged"/>
                                     <Grid ColumnSpacing="10" Margin="0,4,0,0">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*"/>
                                             <ColumnDefinition Width="Auto"/>
                                             <ColumnDefinition Width="Auto"/>
                                         </Grid.ColumnDefinitions>
                                         <NumberBox x:Name="SettingsPruneDaysBox"
                                                    Grid.Column="0"
                                                    Header="Prune logs older than (days)"
                                                    Value="30" Minimum="1" Maximum="365"
                                                    SpinButtonPlacementMode="Compact"
                                                    CornerRadius="4"
                                                    ValueChanged="OnSettingsPruneDaysBoxChanged"/>
                                         <Button x:Name="SettingsPruneNowButton"
                                                 Grid.Column="1"
                                                 Click="OnPruneLogsNowClick"
                                                 Height="36" Width="100" CornerRadius="4"
                                                 Content="Prune Now"
                                                 VerticalAlignment="Bottom"/>
                                         <Button x:Name="SettingsClearLogsButton"
                                                 Grid.Column="2"
                                                 Click="OnClearLogsClick"
                                                 Height="36" Width="100" CornerRadius="4"
                                                 Content="Clear All"
                                                 VerticalAlignment="Bottom"
                                                 Style="{ThemeResource DefaultButtonStyle}"/>
                                     </Grid>
                                 </StackPanel>

                                 <!-- Backup & Restore -->
                                 <StackPanel Spacing="8" Width="560" HorizontalAlignment="Left">
                                     <TextBlock Text="Backup &amp; Restore Configuration"
                                                Style="{ThemeResource BodyTextBlockStyle}"
                                                FontWeight="SemiBold"/>
                                     <TextBlock Text="Export your monitored sites list and settings, or import from a previous backup."
                                                Style="{ThemeResource CaptionTextBlockStyle}"
                                                Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                     <Grid ColumnSpacing="12">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*"/>
                                             <ColumnDefinition Width="*"/>
                                         </Grid.ColumnDefinitions>
                                         <Button x:Name="ExportConfigButton"
                                                 Grid.Column="0"
                                                 Click="OnExportConfigClick"
                                                 HorizontalAlignment="Stretch"
                                                 Height="36" CornerRadius="4">
                                             <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                                 <FontIcon Glyph="&#xE78C;" FontSize="14"/>
                                                 <TextBlock Text="Export Configuration..."/>
                                             </StackPanel>
                                         </Button>
                                         <Button x:Name="ImportConfigButton"
                                                 Grid.Column="1"
                                                 Click="OnImportConfigClick"
                                                 HorizontalAlignment="Stretch"
                                                 Height="36" CornerRadius="4">
                                             <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                                 <FontIcon Glyph="&#xE8B5;" FontSize="14"/>
                                                 <TextBlock Text="Import Configuration..."/>
                                             </StackPanel>
                                         </Button>
                                     </Grid>
                                 </StackPanel>

                                <!-- Validation / confirmation -->
                                <TextBlock x:Name="SettingsValidationText"
                                           Foreground="#DC2626"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                    HorizontalAlignment="Left" Spacing="10" Margin="0,16,0,0">
                            <Button x:Name="SettingsSaveButton"
                                    Content="Save Settings"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    Click="OnSettingsSaveClick"/>
                            <Button x:Name="SettingsDiscardButton"
                                    Content="Discard"
                                    Click="OnSettingsDiscardClick"/>
                            <Button x:Name="SettingsRestoreButton"
                                    Content="Restore to Default"
                                    Click="OnSettingsRestoreClick"/>
                        </StackPanel>
                    </Grid>

                    <!-- ─────────────── Help Page ─────────────── -->
                    <Grid x:Name="HelpPage" Padding="24,16,24,16" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Help &amp; Documentation"
                                   Style="{ThemeResource TitleTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">

                                <TextBlock Text="Frequently Asked Questions (FAQ)" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>

                                <Expander Header="How do I start monitoring a website?"
                                          HorizontalAlignment="Left"
                                          Width="560"
                                          IsExpanded="True"
                                          Margin="0,4,0,4">
                                    <StackPanel Spacing="10" Padding="16">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="1." Style="{ThemeResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Click 'Add Site' in the dashboard or sidebar navigation." TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="2." Style="{ThemeResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Enter a friendly name and the HTTP/HTTPS URL you wish to monitor." TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="3." Style="{ThemeResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Click 'Add Site' to save. The application will start monitoring it immediately." TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="How does the website monitoring work?"
                                          HorizontalAlignment="Left"
                                          Width="560"
                                          IsExpanded="False"
                                          Margin="0,4,0,4">
                                    <StackPanel Spacing="10" Padding="16">
                                        <TextBlock Text="The application performs web requests in the background at your configured check interval. It strips away webpage code (like scripts and styling) and normalizes the text content. It then computes a secure hash (SHA-256) of the text and compares it to the previous run. If the hashes don't match, you'll receive a Windows notification and the Dashboard will show a 'Changed' status badge."
                                                   TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="How do I install the signed package on another PC?"
                                          HorizontalAlignment="Left"
                                          Width="560"
                                          IsExpanded="False"
                                          Margin="0,4,0,4">
                                    <StackPanel Spacing="12" Padding="16">
                                        <TextBlock Text="To share and install this application on other machines:" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        <StackPanel Spacing="6" Margin="12,0,0,0">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="1." Style="{ThemeResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                                                <TextBlock Text="Provide them both the Installer (SiteUpdateNotifier.msix) and the Certificate (NotifierPublisher.cer) from the Installer folder." TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="2." Style="{ThemeResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                                                <TextBlock Text="Double-click the .cer file first, select 'Local Machine', and place it in the 'Trusted Root Certification Authorities' store." TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="3." Style="{ThemeResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                                                <TextBlock Text="Alternatively, run these commands in an Administrator PowerShell session:" TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Code Block 1 -->
                                        <Border BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="1" CornerRadius="4" Padding="10,6" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" HorizontalAlignment="Stretch">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Import-Certificate -FilePath .\NotifierPublisher.cer -CertStoreLocation Cert:\LocalMachine\Root" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap" Grid.Column="0"/>
                                                <Button Grid.Column="1" Click="OnCopyCommandClick" Tag="Import-Certificate -FilePath .\NotifierPublisher.cer -CertStoreLocation Cert:\LocalMachine\Root" Style="{ThemeResource DefaultButtonStyle}" Padding="8,4" Margin="10,0,0,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE8C8;" FontSize="12"/>
                                                        <TextBlock Text="Copy" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <!-- Code Block 2 -->
                                        <Border BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="1" CornerRadius="4" Padding="10,6" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" HorizontalAlignment="Stretch">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Import-Certificate -FilePath .\NotifierPublisher.cer -CertStoreLocation Cert:\LocalMachine\TrustedPeople" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap" Grid.Column="0"/>
                                                <Button Grid.Column="1" Click="OnCopyCommandClick" Tag="Import-Certificate -FilePath .\NotifierPublisher.cer -CertStoreLocation Cert:\LocalMachine\TrustedPeople" Style="{ThemeResource DefaultButtonStyle}" Padding="8,4" Margin="10,0,0,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE8C8;" FontSize="12"/>
                                                        <TextBlock Text="Copy" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="12,0,0,0">
                                            <TextBlock Text="4." Style="{ThemeResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Double-click the .msix file to install the application instantly!" TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="What do the different status indicators mean?"
                                          HorizontalAlignment="Left"
                                          Width="560"
                                          IsExpanded="False"
                                          Margin="0,4,0,4">
                                    <StackPanel Spacing="10" Padding="16">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE73E;" Foreground="#22C55E" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Success (Green): The site was checked successfully and no changes were found." TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE7C8;" Foreground="#EF4444" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Changed (Red): Webpage content changes were detected. A 'View Diff' button appears to inspect edits line-by-line." TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE7BA;" Foreground="#F59E0B" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Error (Amber): The request failed (e.g. timeout, DNS resolution error, or offline)." TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE71B;" Foreground="#94A6B8" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Pending (Gray): The site is scheduled and waiting for its initial or next automatic check run." TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ─────────────── About Page ─────────────── -->
                    <Grid x:Name="AboutPage" Padding="24,16,24,16" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="About"
                                   Style="{ThemeResource TitleTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="20" MaxWidth="600" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE774;" FontSize="48" Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Notifier" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" FontSize="20"/>
                                        <TextBlock Text="{x:Bind DisplayVersion}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Text="A modern Windows App SDK (WinUI 3) utility designed to monitor web content changes and alert you instantly in the system tray. Built with high-performance C# and native Fluent Design system."
                                           TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Developer &amp; Publisher" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    <TextBlock Text="Amitendu Bikash Dhusiya (Shadow Amitendu)" Style="{ThemeResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="24">
                                    <HyperlinkButton NavigateUri="https://github.com/ShadowAmitendu" Padding="0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE71B;" FontSize="14"/>
                                            <TextBlock Text="GitHub Profile" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </HyperlinkButton>

                                    <HyperlinkButton NavigateUri="https://www.linkedin.com/in/amitendu/" Padding="0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE71B;" FontSize="14"/>
                                            <TextBlock Text="LinkedIn Profile" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </HyperlinkButton>
                                </StackPanel>
                                
                                <Border BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" 
                                        BorderThickness="0,1,0,0" 
                                        Margin="0,12,0,0" 
                                        Padding="0,16,0,0">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="App Updates" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                            <Button x:Name="SettingsCheckUpdatesButton" 
                                                    Content="Check for Updates" 
                                                    Click="OnCheckUpdatesClick"
                                                    Style="{ThemeResource AccentButtonStyle}"
                                                    Height="32" Padding="16,0,16,0" CornerRadius="4"/>
                                            <TextBlock x:Name="SettingsUpdateStatusText" 
                                                       Text="" 
                                                       VerticalAlignment="Center" 
                                                       Style="{ThemeResource BodyTextBlockStyle}" 
                                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                            <ProgressRing x:Name="SettingsUpdateProgressRing" 
                                                          IsActive="False" 
                                                          Width="20" Height="20" 
                                                          VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ProgressBar x:Name="SettingsUpdateProgressBar" 
                                                     Visibility="Collapsed" 
                                                     Minimum="0" Maximum="100" Value="0" 
                                                     Width="300" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                                
                                <TextBlock Text="Licensed under the MIT License. All rights reserved." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </NavigationView.Content>
        </NavigationView>
        
        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Height="32" 
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" 
                BorderThickness="0,1,0,0" 
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid Margin="16,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left side: Status status -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusBarIcon" Width="8" Height="8" Fill="#94A3B8" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusBarText" Text="Monitoring Disabled" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Right side: Countdown -->
                <TextBlock x:Name="StatusBarCountdownText" Text="" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

    </Grid>
</Window>
